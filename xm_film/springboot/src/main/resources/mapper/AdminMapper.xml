<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springboot.mapper.AdminMapper">

    <!-- 查询操作 -->
    <select id="selectAll" resultType="com.example.springboot.entity.Admin">
        SELECT * FROM admin
        <where>
            <if test="name != null">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectById" parameterType="java.lang.Integer" resultType="com.example.springboot.entity.Admin">
        SELECT * FROM admin WHERE id = #{id}
    </select>

    <!-- 插入操作 -->
    <insert id="insert" parameterType="com.example.springboot.entity.Admin">
        INSERT INTO admin (id, username, password, role, name, avatar, phone, email)
        VALUES (#{id}, #{username}, #{password}, #{role}, #{name}, #{avatar}, #{phone}, #{email})
    </insert>

    <!-- 查询管理员名字   -->
    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.example.springboot.entity.Admin">
        SELECT * FROM admin WHERE username = #{username}
    </select>

    <!-- 更新操作 -->
    <update id="updateById" parameterType="com.example.springboot.entity.Admin">
        UPDATE admin
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="role != null">role = #{role},</if>
            <if test="name != null">name = #{name},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email}</if>
        </set>
        WHERE id = #{id}
    </update>

    <update id="updatePassword" parameterType="com.example.springboot.entity.Admin">
        UPDATE admin SET password = #{password} WHERE id = #{id}
    </update>

    <!-- 删除操作 -->
    <delete id="deleteById" parameterType="com.example.springboot.entity.Admin">
        DELETE FROM admin WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM admin WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
