<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springboot.mapper.UserMapper">

    <!-- 查询操作 -->
    <select id="selectAll" resultType="com.example.springboot.entity.User">
        SELECT * FROM user
        <where>
            <if test="name != null">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="username != null">
                AND username LIKE CONCAT('%', #{username}, '%')
            </if>
            <if test="role != null">
                AND role = #{role}
            </if>
            <if test="phone != null">
                AND phone LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="email != null">
                AND email LIKE CONCAT('%', #{email}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <!-- 插入操作 -->
    <insert id="insert" parameterType="com.example.springboot.entity.User">
        INSERT INTO user (id, username, password, role, name, avatar, phone, email)
        VALUES (#{id}, #{username}, #{password}, #{role}, #{name}, #{avatar}, #{phone}, #{email})
    </insert>

    <!-- 查询名字 -->
    <select id="selectByUsername" parameterType="java.lang.String" resultType="com.example.springboot.entity.User">
        SELECT * FROM user WHERE username = #{username}
    </select>

    <!-- 更新操作 -->
    <update id="updateById" parameterType="com.example.springboot.entity.User">
        UPDATE user
        <set>
            <if test="username != null">username = #{username},</if>
            <if test="password != null">password = #{password},</if>
            <if test="role != null">role = #{role},</if>
            <if test="name != null">name = #{name},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email}</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除操作 -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM user WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM user WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>