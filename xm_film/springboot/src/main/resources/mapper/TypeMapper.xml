<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springboot.mapper.TypeMapper">

    <!-- 查询操作 -->
    <select id="selectAll" resultType="com.example.springboot.entity.Type">
        SELECT * FROM type
        <where>
            <if test="title != null">
                AND title LIKE CONCAT('%', #{title}, '%')
            </if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectByIds" resultType="com.example.springboot.entity.Type">
        SELECT * FROM type WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>


    <!-- 插入操作 -->
    <insert id="insert" parameterType="com.example.springboot.entity.Type">
        INSERT INTO type (id, title)
        VALUES (#{id}, #{title})
    </insert>


    <!-- 更新操作 -->
    <update id="updateById" parameterType="com.example.springboot.entity.Type">
        UPDATE type
        <set>
            <if test="title != null">title = #{title},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除操作 -->
    <delete id="deleteById" parameterType="com.example.springboot.entity.Type">
        DELETE FROM type WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM type WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>