<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.springboot.mapper.MarkMapper">

    <!-- 查询操作 -->
    <select id="selectAll" resultType="com.example.springboot.entity.Mark">
        SELECT
        mark.*,
        user.name as userName,
        film.title as filmName
        FROM mark
        LEFT JOIN user ON mark.user_id = user.id
        LEFT JOIN film ON mark.film_id = film.id
        <where>
            <if test="userId != null">AND mark.user_id = #{userId} </if>
            <if test="filmId != null">AND mark.film_id = #{filmId} </if>
        </where>
        ORDER BY id DESC
    </select>

    <select id="selectById" parameterType="java.lang.Integer" resultType="com.example.springboot.entity.Mark">
        SELECT
        mark.*,
        user.name as userName,
        film.title as filmName
        FROM mark
        LEFT JOIN user ON mark.user_id = user.id
        LEFT JOIN film ON mark.film_id = film.id
        WHERE mark.id = #{id}
    </select>

    <!-- 插入操作 -->
    <insert id="insert" parameterType="com.example.springboot.entity.Mark"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mark
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="filmId != null">film_id,</if>
            <if test="img != null">img,</if>
            <if test="mark != null">mark,</if>
        </trim>
        VALUES
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="filmId != null">#{filmId},</if>
            <if test="img != null">#{img},</if>
            <if test="mark != null">#{mark},</if>
        </trim>
    </insert>

    <!-- 更新操作 -->
    <update id="updateById" parameterType="com.example.springboot.entity.Mark">
        UPDATE mark
        <set>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="filmId != null">film_id = #{filmId},</if>
            <if test="img != null">img = #{img},</if>
            <if test="mark != null">mark = #{mark},</if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除操作 -->
    <delete id="deleteById" parameterType="java.lang.Integer">
        DELETE FROM mark WHERE id = #{id}
    </delete>

    <delete id="deleteBatch">
        DELETE FROM mark WHERE id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
